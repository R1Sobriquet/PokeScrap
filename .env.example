# --- App ---
APP_ENV=development
APP_TIMEZONE=Europe/Paris
API_PORT=8000
FRONTEND_PORT=5173

# --- Auth (mono-utilisateur) ---
JWT_SECRET=change_me
JWT_EXPIRE_MIN=720
ADMIN_USERNAME=erwann
ADMIN_PASSWORD=change_me            # haché en bcrypt au premier démarrage

# --- MySQL ---
DB_HOST=db
DB_PORT=3306
DB_NAME=pokemon_arbitrage
DB_USER=app
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me

# --- PokeTrace (clé serveur uniquement, JAMAIS côté frontend) ---
POKETRACE_API_KEY=
POKETRACE_BASE_URL=https://api.poketrace.com/v1

# --- PSA Public API ---
# Réel : token statique généré dans le compte PSA (prioritaire). Username/password
# = repli OAuth2 (spec d'origine). Base réelle : api.psacard.com/publicapi.
PSA_API_TOKEN=
PSA_API_USERNAME=
PSA_API_PASSWORD=
PSA_BASE_URL=https://api.psacard.com/publicapi

# --- Discord (bot gateway) ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ACHATS=
DISCORD_CHANNEL_VENTES=
DISCORD_CHANNEL_PORTEFEUILLE=
DISCORD_CHANNEL_SYSTEME=
DISCORD_PING_USER_ID=

# --- Scraper ---
SCRAPE_VINTED_ENABLED=true
SCRAPE_LBC_ENABLED=true
SCRAPE_INTERVAL_MIN=45
SCRAPE_USER_AGENT=
# Cookies de session OPTIONNELS (compte perso dédié), au format JSON Playwright
# (liste d'objets cookie). Laisser vide = scraping anonyme. Jamais d'identifiants
# en clair : seulement des cookies exportés.
SCRAPE_VINTED_COOKIES=
SCRAPE_LBC_COOKIES=
# Anti-détection légère. SCRAPE_HEADLESS=false nécessite un affichage (xvfb) ;
# en conteneur, laisser true. State (cookies persistés) + screenshots de debug.
SCRAPE_HEADLESS=true
SCRAPE_STATE_DIR=/app/state
SCRAPE_DEBUG_DIR=/tmp/scraper-debug

# --- Jobs (cron) ---
JOB_REFRESH_PRICES=0 6 * * *
JOB_REFRESH_HISTORY=0 4 * * *
JOB_KPI_SNAPSHOT=55 23 * * *

# --- Logs ---
LOG_LEVEL=info
LOG_REDACT_SECRETS=true            # masque les secrets dans les logs JSON

# --- Sauvegardes (J9) ---
BACKUP_DIR=./backups               # dépôt local des dumps chiffrés
BACKUP_OFFSITE_TARGET=             # ex. rclone:remote:pokescrap ou user@host:/path (scp)
BACKUP_ENCRYPTION_KEY=             # recipient age (age1...) OU empreinte/clé GPG
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_SCHEDULE=0 3 * * *          # 03:00 (cron hôte)
